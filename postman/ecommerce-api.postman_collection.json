{
  "info": {
    "name": "E-Commerce API",
    "description": "Requests for testing Categories, Products, Cart, and Orders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" }
        },
        {
          "name": "Create Category",
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json()", "pm.environment.set('categoryId', json.data._id)"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Accessories\",\n  \"description\": \"Computer and phone accessories\"\n}" },
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Get Category By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/categories/{{categoryId}}" }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated accessories\"\n}" },
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/categories/{{categoryId}}" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products" }
        },
        {
          "name": "Filter Products By Category",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?category={{categoryId}}" }
        },
        {
          "name": "Filter Products By Minimum Price",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?minPrice=20" }
        },
        {
          "name": "Filter Products By Maximum Price",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?maxPrice=800" }
        },
        {
          "name": "Filter Products By Price Range",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?minPrice=20&maxPrice=800" }
        },
        {
          "name": "Filter Products In Stock",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?inStock=true" }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products?search=phone" }
        },
        {
          "name": "Create Product",
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json()", "pm.environment.set('productId', json.data._id)"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Wireless Mouse\",\n  \"description\": \"Simple wireless mouse\",\n  \"price\": 30,\n  \"stock\": 12,\n  \"category\": \"{{categoryId}}\",\n  \"images\": [\"mouse.jpg\"]\n}" },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Get Product By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/{{productId}}" }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 35,\n  \"stock\": 10\n}" },
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/products/{{productId}}" }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json()", "pm.environment.set('cartId', json.data._id)"] } }],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/cart" }
        },
        {
          "name": "Add Item To Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}" },
            "url": "{{baseUrl}}/api/cart/items"
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" },
            "url": "{{baseUrl}}/api/cart/items/{{productId}}"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/cart/items/{{productId}}" }
        },
        {
          "name": "Clear Cart",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/cart" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get All Orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders" }
        },
        {
          "name": "Create Order",
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json()", "pm.environment.set('orderId', json.data._id)"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"shippingAddress\": {\n    \"street\": \"12 Main Street\",\n    \"city\": \"Cairo\",\n    \"country\": \"Egypt\"\n  }\n}" },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Get Order By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders/{{orderId}}" }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"confirmed\"\n}" },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status"
          }
        }
      ]
    }
  ]
}
